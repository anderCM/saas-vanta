<%= form_with(model: dispatch_guide, class: "space-y-6", data: { controller: "dispatch-guide-form" }) do |f| %>
  <% if dispatch_guide.errors.any? %>
    <div class="alert-error">
      <ul class="list-disc list-inside text-sm">
        <% dispatch_guide.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# Documento vinculado %>
  <% source_sale = dispatch_guide.sourceable if dispatch_guide.sourceable.is_a?(Sale) %>
  <% if source_sale&.sunat_uuid.present? %>
    <div class="flex items-start gap-3 p-4 bg-primary/5 border border-primary/20 rounded-lg">
      <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
      </svg>
      <div>
        <p class="text-sm font-medium text-foreground">
          Esta guia se vinculara con
          <span class="font-mono"><%= source_sale.sunat_document_type == "01" ? "Factura" : "Boleta" %> <%= source_sale.sunat_series %>-<%= source_sale.sunat_number %></span>
        </p>
        <p class="text-xs text-muted-foreground mt-0.5">
          El comprobante sera referenciado automaticamente en el XML de SUNAT.
        </p>
      </div>
    </div>
  <% end %>

  <%# Informacion General %>
  <div class="card">
    <h3 class="text-sm font-semibold text-foreground mb-3">Informacion General</h3>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div>
        <%= f.label :code, "Codigo", class: "form-label" %>
        <%= f.text_field :code, class: "form-input bg-muted", readonly: true %>
      </div>

      <div>
        <%= f.label :guide_type, "Tipo de Guia", class: "form-label" %>
        <%= f.select :guide_type, [["Remitente (GRR)", "grr"], ["Transportista (GRT)", "grt"]], {}, class: "form-input", data: { action: "dispatch-guide-form#toggleGuideType" } %>
      </div>

      <div>
        <%= f.label :transfer_reason, "Motivo de Traslado", class: "form-label" %>
        <%= f.select :transfer_reason, [
          ["Venta", "venta"],
          ["Compra", "compra"],
          ["Traslado entre establecimientos", "traslado_entre_establecimientos"],
          ["Importacion", "importacion"],
          ["Exportacion", "exportacion"],
          ["Otros", "otros"]
        ], {}, class: "form-input" %>
      </div>

      <div>
        <%= f.label :issue_date, "Fecha de Emision", class: "form-label" %>
        <%= f.date_field :issue_date, class: "form-input", required: true %>
      </div>

      <div>
        <%= f.label :transfer_date, "Fecha de Traslado", class: "form-label" %>
        <%= f.date_field :transfer_date, class: "form-input", required: true %>
      </div>

      <div>
        <%= f.label :gross_weight, "Peso Bruto (KG)", class: "form-label" %>
        <%= f.number_field :gross_weight, class: "form-input", step: "0.01", min: "0" %>
      </div>
    </div>
  </div>

  <%# Direcciones %>
  <div class="card">
    <h3 class="text-sm font-semibold text-foreground mb-3">Direcciones</h3>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <div class="space-y-4">
        <h4 class="text-sm font-medium text-muted-foreground">Punto de Partida</h4>
        <div>
          <%= f.label :departure_address, "Direccion", class: "form-label" %>
          <%= f.text_field :departure_address, class: "form-input", required: true %>
        </div>
        <%= render "shared/async_combobox",
            name: "dispatch_guide[departure_ubigeo_id]",
            src: ubigeos_path,
            value: dispatch_guide.departure_ubigeo_id,
            display: dispatch_guide.departure_ubigeo&.combobox_display,
            label: "Ubigeo",
            placeholder: "Buscar distrito...",
            hint: "Escribe para buscar",
            size: "full" %>
      </div>

      <div class="space-y-4">
        <h4 class="text-sm font-medium text-muted-foreground">Punto de Llegada</h4>
        <div>
          <%= f.label :arrival_address, "Direccion", class: "form-label" %>
          <%= f.text_field :arrival_address, class: "form-input", required: true %>
        </div>
        <%= render "shared/async_combobox",
            name: "dispatch_guide[arrival_ubigeo_id]",
            src: ubigeos_path,
            value: dispatch_guide.arrival_ubigeo_id,
            display: dispatch_guide.arrival_ubigeo&.combobox_display,
            label: "Ubigeo",
            placeholder: "Buscar distrito...",
            hint: "Escribe para buscar",
            size: "full" %>
      </div>
    </div>
  </div>

  <%# Destinatario (GRR) / Remitente (GRT) %>
  <div class="card" data-dispatch-guide-form-target="recipientSection">
    <h3 class="text-sm font-semibold text-foreground mb-3">
      <%= dispatch_guide.grt? ? "Remitente" : "Destinatario" %>
    </h3>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <% if dispatch_guide.grr? %>
        <div>
          <%= f.label :recipient_doc_type, "Tipo de Documento", class: "form-label" %>
          <%= f.select :recipient_doc_type, [["RUC", "ruc"], ["DNI", "dni"]], {}, class: "form-input" %>
        </div>
        <div>
          <%= f.label :recipient_doc_number, "Numero de Documento", class: "form-label" %>
          <%= f.text_field :recipient_doc_number, class: "form-input" %>
        </div>
        <div>
          <%= f.label :recipient_name, "Nombre / Razon Social", class: "form-label" %>
          <%= f.text_field :recipient_name, class: "form-input" %>
        </div>
      <% else %>
        <div>
          <%= f.label :shipper_doc_type, "Tipo de Documento", class: "form-label" %>
          <%= f.select :shipper_doc_type, [["RUC", "ruc"], ["DNI", "dni"]], {}, class: "form-input" %>
        </div>
        <div>
          <%= f.label :shipper_doc_number, "Numero de Documento", class: "form-label" %>
          <%= f.text_field :shipper_doc_number, class: "form-input" %>
        </div>
        <div>
          <%= f.label :shipper_name, "Nombre / Razon Social", class: "form-label" %>
          <%= f.text_field :shipper_name, class: "form-input" %>
        </div>
      <% end %>
    </div>
  </div>

  <%# Transporte %>
  <div class="card">
    <h3 class="text-sm font-semibold text-foreground mb-3">Transporte</h3>

    <div class="mb-4">
      <%= f.label :transport_modality, "Modalidad", class: "form-label" %>
      <%= f.select :transport_modality, [["Transporte Privado", "private"], ["Transporte Publico", "public"]], {}, class: "form-input", data: { action: "dispatch-guide-form#toggleTransport" } %>
    </div>

    <%# Transporte Privado %>
    <div data-dispatch-guide-form-target="privateTransport" class="<%= 'hidden' if dispatch_guide.public_transport? %>">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <%= f.label :vehicle_id, "Vehiculo", class: "form-label" %>
          <%= turbo_frame_tag "vehicle-select" do %>
            <%= f.collection_select :vehicle_id, @vehicles, :id, :combobox_display, { include_blank: "Seleccionar vehiculo" }, class: "form-input" %>
          <% end %>
          <p class="text-xs text-muted-foreground mt-1">
            <%= link_to "Registrar nuevo vehiculo", new_vehicle_path, data: { turbo_frame: "modal" }, class: "text-primary hover:underline" %>
          </p>
        </div>
        <div>
          <%= f.label :driver_id, "Conductor", class: "form-label" %>
          <%= f.collection_select :driver_id, @drivers, :id, :full_name, { include_blank: "Seleccionar conductor" }, class: "form-input" %>
          <p class="text-xs text-muted-foreground mt-1">Usuarios con rol "Conductor"</p>
        </div>
      </div>
    </div>

    <%# Transporte Publico %>
    <div data-dispatch-guide-form-target="publicTransport" class="<%= 'hidden' unless dispatch_guide.public_transport? %>">
      <div>
        <%= f.label :carrier_id, "Transportista", class: "form-label" %>
        <%= turbo_frame_tag "carrier-select" do %>
          <%= f.collection_select :carrier_id, @carriers, :id, :combobox_display, { include_blank: "Seleccionar transportista" }, class: "form-input" %>
        <% end %>
        <p class="text-xs text-muted-foreground mt-1">
          <%= link_to "Registrar nuevo transportista", new_carrier_path, data: { turbo_frame: "modal" }, class: "text-primary hover:underline" %>
        </p>
      </div>
    </div>
  </div>

  <%# Items %>
  <div class="card">
    <h3 class="text-sm font-semibold text-foreground mb-3">Items</h3>

    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-border" id="dispatch-guide-items-table">
        <thead class="bg-muted/50">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium text-muted-foreground uppercase">Descripcion</th>
            <th class="px-4 py-3 text-right text-xs font-medium text-muted-foreground uppercase w-32">Cantidad</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-muted-foreground uppercase w-32">Unidad</th>
            <th class="px-4 py-3 w-12"></th>
          </tr>
        </thead>
        <tbody id="dispatch-guide-items" class="divide-y divide-border">
          <% dispatch_guide.items.each_with_index do |item, index| %>
            <%= render "item_fields", f: f, item: item, index: index %>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="mt-4">
      <button type="button" class="btn-secondary text-sm" onclick="addDispatchGuideItem()">
        + Agregar Item
      </button>
    </div>
  </div>

  <%# Observaciones %>
  <div class="card">
    <h3 class="text-sm font-semibold text-foreground mb-3">Observaciones</h3>
    <%= f.text_area :notes, class: "form-input", rows: 3, placeholder: "Observaciones adicionales..." %>
  </div>

  <%# Sourceable hidden %>
  <% if dispatch_guide.sourceable_type.present? %>
    <%= f.hidden_field :sourceable_type, value: dispatch_guide.sourceable_type %>
    <%= f.hidden_field :sourceable_id, value: dispatch_guide.sourceable_id %>
  <% end %>

  <div class="flex items-center gap-3">
    <%= f.submit dispatch_guide.persisted? ? "Actualizar Guia" : "Crear Guia", class: "btn-primary cursor-pointer", data: { turbo_submits_with: "Guardando..." } %>
    <%= link_to "Cancelar", dispatch_guides_path, class: "btn-secondary" %>
  </div>
<% end %>

<template id="dispatch-guide-item-template">
  <tr class="dispatch-guide-item-row">
    <td class="px-4 py-3">
      <input type="text" name="dispatch_guide[items_attributes][__INDEX__][description]" class="form-input" placeholder="Descripcion del item" required>
    </td>
    <td class="px-4 py-3">
      <input type="number" name="dispatch_guide[items_attributes][__INDEX__][quantity]" class="form-input text-right" step="0.01" min="0.01" required>
    </td>
    <td class="px-4 py-3">
      <select name="dispatch_guide[items_attributes][__INDEX__][unit_code]" class="form-input">
        <option value="NIU">NIU (Unidad)</option>
        <option value="KGM">KGM (Kilogramo)</option>
        <option value="LTR">LTR (Litro)</option>
        <option value="MTR">MTR (Metro)</option>
        <option value="BX">BX (Caja)</option>
        <option value="GLL">GLL (Galon)</option>
      </select>
    </td>
    <td class="px-4 py-3 text-center">
      <button type="button" onclick="removeDispatchGuideItem(this)" class="text-destructive hover:text-destructive/80">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
        </svg>
      </button>
    </td>
  </tr>
</template>

<script>
  let dispatchGuideItemIndex = <%= dispatch_guide.items.size %>;

  function addDispatchGuideItem() {
    const template = document.getElementById('dispatch-guide-item-template');
    const tbody = document.getElementById('dispatch-guide-items');
    const html = template.innerHTML.replace(/__INDEX__/g, dispatchGuideItemIndex);
    tbody.insertAdjacentHTML('beforeend', html);
    dispatchGuideItemIndex++;
  }

  function removeDispatchGuideItem(button) {
    const row = button.closest('tr');
    const destroyInput = row.querySelector('input[name*="_destroy"]');
    if (destroyInput) {
      destroyInput.value = '1';
      row.style.display = 'none';
    } else {
      row.remove();
    }
  }
</script>
