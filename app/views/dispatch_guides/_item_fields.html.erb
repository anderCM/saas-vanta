<tr class="dispatch-guide-item-row">
  <td class="px-4 py-3">
    <% if item.persisted? %>
      <%= hidden_field_tag "dispatch_guide[items_attributes][#{index}][id]", item.id %>
    <% end %>
    <%= hidden_field_tag "dispatch_guide[items_attributes][#{index}][_destroy]", "0" %>
    <% if item.product_id.present? %>
      <%= hidden_field_tag "dispatch_guide[items_attributes][#{index}][product_id]", item.product_id %>
    <% end %>
    <input type="text" name="dispatch_guide[items_attributes][<%= index %>][description]" value="<%= item.description %>" class="form-input" placeholder="Descripcion del item" required>
  </td>
  <td class="px-4 py-3">
    <input type="number" name="dispatch_guide[items_attributes][<%= index %>][quantity]" value="<%= item.quantity %>" class="form-input text-right" step="0.01" min="0.01" required>
  </td>
  <td class="px-4 py-3">
    <select name="dispatch_guide[items_attributes][<%= index %>][unit_code]" class="form-input">
      <option value="NIU" <%= 'selected' if item.unit_code == 'NIU' %>>NIU (Unidad)</option>
      <option value="KGM" <%= 'selected' if item.unit_code == 'KGM' %>>KGM (Kilogramo)</option>
      <option value="LTR" <%= 'selected' if item.unit_code == 'LTR' %>>LTR (Litro)</option>
      <option value="MTR" <%= 'selected' if item.unit_code == 'MTR' %>>MTR (Metro)</option>
      <option value="BX" <%= 'selected' if item.unit_code == 'BX' %>>BX (Caja)</option>
      <option value="GLL" <%= 'selected' if item.unit_code == 'GLL' %>>GLL (Galon)</option>
    </select>
  </td>
  <td class="px-4 py-3 text-center">
    <button type="button" onclick="removeDispatchGuideItem(this)" class="text-destructive hover:text-destructive/80">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
      </svg>
    </button>
  </td>
</tr>
