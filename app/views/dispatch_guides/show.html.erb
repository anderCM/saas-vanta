<% content_for :page_title, @dispatch_guide.code %>
<% add_breadcrumb "Despacho" %>
<% add_breadcrumb "Guias de Remision", dispatch_guides_path %>
<% add_breadcrumb @dispatch_guide.code %>

<div class="max-w-5xl mx-auto space-y-6">
  <%# Header %>
  <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4">
    <div class="space-y-3">
      <div class="flex items-center gap-3">
        <h1 class="text-xl font-semibold text-foreground font-mono"><%= @dispatch_guide.code %></h1>
        <span class="badge-secondary"><%= @dispatch_guide.guide_type_label %></span>
      </div>
      <p class="text-sm text-muted-foreground">
        Creada por <%= @dispatch_guide.created_by.first_name %> el <%= l(@dispatch_guide.created_at, format: :long) %>
      </p>
      <%= render "shared/documents/status_bar",
          steps: [
            { key: "draft", label: "Borrador" },
            { key: "confirmed", label: "Confirmada" }
          ],
          current: @dispatch_guide.status,
          cancelled: @dispatch_guide.cancelled? %>
    </div>
    <div class="flex flex-wrap gap-2">
      <%= link_to "Volver", dispatch_guides_path, class: "btn-secondary" %>

      <% if @dispatch_guide.can_edit? && policy(@dispatch_guide).update? %>
        <%= link_to "Editar", edit_dispatch_guide_path(@dispatch_guide), class: "btn-secondary" %>
      <% end %>

      <% if @dispatch_guide.can_emit_document? && policy(@dispatch_guide).emit_document? %>
        <% doc_type = @dispatch_guide.grr? ? "Guia Remitente" : "Guia Transportista" %>
        <%= button_to "Emitir #{doc_type}", emit_document_dispatch_guide_path(@dispatch_guide),
            method: :post, class: "btn-primary",
            data: { turbo_confirm: "Se emitira una #{doc_type} electronica a SUNAT. Continuar?" } %>
      <% end %>

      <% if @dispatch_guide.can_cancel? && policy(@dispatch_guide).cancel? %>
        <%= button_to "Cancelar", cancel_dispatch_guide_path(@dispatch_guide),
            method: :patch, class: "btn-destructive",
            data: { turbo_confirm: "Cancelar esta guia? Esta accion no se puede deshacer." } %>
      <% end %>
    </div>
  </div>

  <%# Info Cards %>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
    <div class="card">
      <h3 class="text-xs font-medium text-muted-foreground uppercase tracking-wide mb-2">Motivo de Traslado</h3>
      <p class="text-sm font-medium text-foreground"><%= @dispatch_guide.transfer_reason_label %></p>
    </div>

    <div class="card">
      <h3 class="text-xs font-medium text-muted-foreground uppercase tracking-wide mb-2">Modalidad de Transporte</h3>
      <p class="text-sm font-medium text-foreground"><%= @dispatch_guide.transport_modality_label %></p>
    </div>

    <div class="card">
      <h3 class="text-xs font-medium text-muted-foreground uppercase tracking-wide mb-2">Fechas</h3>
      <p class="text-sm text-foreground"><span class="font-medium">Emision:</span> <%= l(@dispatch_guide.issue_date, format: :long) %></p>
      <p class="text-sm text-foreground"><span class="font-medium">Traslado:</span> <%= l(@dispatch_guide.transfer_date, format: :long) %></p>
    </div>
  </div>

  <%# Addresses %>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
    <div class="card">
      <h3 class="text-xs font-medium text-muted-foreground uppercase tracking-wide mb-2">Punto de Partida</h3>
      <p class="text-sm font-medium text-foreground"><%= @dispatch_guide.departure_address %></p>
      <% if @dispatch_guide.departure_ubigeo.present? %>
        <p class="text-xs text-muted-foreground mt-0.5"><%= @dispatch_guide.departure_ubigeo.full_path %></p>
      <% end %>
    </div>

    <div class="card">
      <h3 class="text-xs font-medium text-muted-foreground uppercase tracking-wide mb-2">Punto de Llegada</h3>
      <p class="text-sm font-medium text-foreground"><%= @dispatch_guide.arrival_address %></p>
      <% if @dispatch_guide.arrival_ubigeo.present? %>
        <p class="text-xs text-muted-foreground mt-0.5"><%= @dispatch_guide.arrival_ubigeo.full_path %></p>
      <% end %>
    </div>
  </div>

  <% if @dispatch_guide.grr? && @dispatch_guide.recipient_name.present? %>
    <div class="card">
      <h3 class="text-xs font-medium text-muted-foreground uppercase tracking-wide mb-2">Destinatario</h3>
      <p class="text-sm font-medium text-foreground"><%= @dispatch_guide.recipient_name %></p>
      <p class="text-xs text-muted-foreground mt-0.5"><%= @dispatch_guide.recipient_doc_type&.upcase %>: <%= @dispatch_guide.recipient_doc_number %></p>
    </div>
  <% end %>

  <% if @dispatch_guide.grt? && @dispatch_guide.shipper_name.present? %>
    <div class="card">
      <h3 class="text-xs font-medium text-muted-foreground uppercase tracking-wide mb-2">Remitente</h3>
      <p class="text-sm font-medium text-foreground"><%= @dispatch_guide.shipper_name %></p>
      <p class="text-xs text-muted-foreground mt-0.5"><%= @dispatch_guide.shipper_doc_type&.upcase %>: <%= @dispatch_guide.shipper_doc_number %></p>
    </div>
  <% end %>

  <%# Transport %>
  <div class="card">
    <h3 class="text-xs font-medium text-muted-foreground uppercase tracking-wide mb-3">Transporte</h3>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-sm">
      <% if @dispatch_guide.private_transport? %>
        <% if @dispatch_guide.vehicle.present? %>
          <div>
            <dt class="text-xs text-muted-foreground">Vehiculo</dt>
            <dd class="font-medium text-foreground mt-0.5"><%= @dispatch_guide.vehicle.combobox_display %></dd>
          </div>
        <% end %>
        <% if @dispatch_guide.driver.present? %>
          <div>
            <dt class="text-xs text-muted-foreground">Conductor</dt>
            <dd class="font-medium text-foreground mt-0.5"><%= @dispatch_guide.driver.full_name %></dd>
          </div>
        <% end %>
      <% else %>
        <div>
          <dt class="text-xs text-muted-foreground">Transportista</dt>
          <dd class="font-medium text-foreground mt-0.5"><%= @dispatch_guide.carrier_name %></dd>
        </div>
        <div>
          <dt class="text-xs text-muted-foreground">RUC Transportista</dt>
          <dd class="font-medium text-foreground mt-0.5 font-mono"><%= @dispatch_guide.carrier_ruc %></dd>
        </div>
      <% end %>
      <% if @dispatch_guide.gross_weight.present? %>
        <div>
          <dt class="text-xs text-muted-foreground">Peso Bruto (KG)</dt>
          <dd class="font-medium text-foreground mt-0.5 tabular-nums"><%= @dispatch_guide.gross_weight %></dd>
        </div>
      <% end %>
    </div>
  </div>

  <%# Items Table %>
  <div class="card p-0">
    <div class="px-5 py-4 border-b border-border">
      <h3 class="text-sm font-semibold text-foreground">Items</h3>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-border">
        <thead>
          <tr class="bg-muted/40">
            <th class="px-5 py-2.5 text-left text-xs font-medium text-muted-foreground uppercase w-10">#</th>
            <th class="px-5 py-2.5 text-left text-xs font-medium text-muted-foreground uppercase">Descripcion</th>
            <th class="px-5 py-2.5 text-right text-xs font-medium text-muted-foreground uppercase">Cantidad</th>
            <th class="px-5 py-2.5 text-left text-xs font-medium text-muted-foreground uppercase">Unidad</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border">
          <% @dispatch_guide.items.each_with_index do |item, index| %>
            <tr>
              <td class="px-5 py-3 text-sm text-muted-foreground"><%= index + 1 %></td>
              <td class="px-5 py-3 text-sm font-medium text-foreground"><%= item.description %></td>
              <td class="px-5 py-3 text-sm text-foreground text-right tabular-nums"><%= item.quantity %></td>
              <td class="px-5 py-3 text-sm text-muted-foreground"><%= item.unit_code %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <% if @dispatch_guide.notes.present? %>
    <div class="card">
      <h3 class="text-xs font-medium text-muted-foreground uppercase tracking-wide mb-2">Observaciones</h3>
      <p class="text-sm text-foreground whitespace-pre-wrap"><%= @dispatch_guide.notes %></p>
    </div>
  <% end %>

  <%# SUNAT Section %>
  <% if @dispatch_guide.sunat_uuid.present? %>
    <div class="card">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-sm font-semibold text-foreground">Documento Electronico</h3>
        <span class="<%= @dispatch_guide.sunat_status_badge_class %>"><%= @dispatch_guide.sunat_status %></span>
      </div>
      <dl class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-sm">
        <div>
          <dt class="text-xs text-muted-foreground uppercase tracking-wide">Tipo</dt>
          <dd class="font-medium text-foreground mt-0.5"><%= @dispatch_guide.sunat_document_type_label %></dd>
        </div>
        <% if @dispatch_guide.sunat_series.present? %>
          <div>
            <dt class="text-xs text-muted-foreground uppercase tracking-wide">Serie - Numero</dt>
            <dd class="font-medium text-foreground mt-0.5 font-mono"><%= @dispatch_guide.sunat_formatted_number %></dd>
          </div>
        <% end %>
        <div>
          <dt class="text-xs text-muted-foreground uppercase tracking-wide">UUID</dt>
          <dd class="font-medium text-foreground mt-0.5 text-xs font-mono"><%= @dispatch_guide.sunat_uuid %></dd>
        </div>
      </dl>

      <% if @dispatch_guide.sunat_cdr_code.present? %>
        <div class="mt-4 p-3 bg-muted rounded-lg text-sm">
          <span class="text-muted-foreground">Respuesta SUNAT:</span>
          <span class="font-medium text-foreground"><%= @dispatch_guide.sunat_cdr_code %></span>
          <% if @dispatch_guide.sunat_cdr_description.present? %>
            <span class="text-muted-foreground">- <%= @dispatch_guide.sunat_cdr_description %></span>
          <% end %>
        </div>
      <% end %>

      <div class="mt-4 flex flex-wrap gap-2">
        <%= link_to "Consultar Estado", check_sunat_status_dispatch_guide_path(@dispatch_guide), class: "btn-secondary" %>
        <% if @dispatch_guide.can_retry_document? && policy(@dispatch_guide).retry_document? %>
          <%= button_to "Reintentar Envio", retry_document_dispatch_guide_path(@dispatch_guide),
              method: :post, class: "btn-secondary",
              data: { turbo_confirm: "Reintentar el envio de la guia a SUNAT?" } %>
        <% end %>
        <% if @dispatch_guide.sunat_status == "ACCEPTED" %>
          <%= link_to "PDF", pdf_dispatch_guide_path(@dispatch_guide), class: "btn-primary", data: { turbo: false } %>
          <% if @dispatch_guide.sunat_xml.present? %>
            <%= link_to "XML", sunat_xml_dispatch_guide_path(@dispatch_guide), class: "btn-secondary", data: { turbo: false } %>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if @dispatch_guide.sourceable.present? %>
    <div class="card">
      <h3 class="text-xs font-medium text-muted-foreground uppercase tracking-wide mb-2">Origen</h3>
      <p class="text-sm text-foreground">
        Generada desde venta
        <%= link_to @dispatch_guide.sourceable.code, sale_path(@dispatch_guide.sourceable), class: "link-primary font-medium font-mono" %>
      </p>
      <% if @dispatch_guide.sourceable.is_a?(Sale) && @dispatch_guide.sourceable.sunat_uuid.present? %>
        <div class="flex items-center gap-2 mt-2 pt-2 border-t border-border">
          <svg class="w-4 h-4 text-primary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
          </svg>
          <p class="text-sm text-foreground">
            Vinculada con
            <span class="font-mono font-medium">
              <%= @dispatch_guide.sourceable.sunat_document_type == "01" ? "Factura" : "Boleta" %>
              <%= @dispatch_guide.sourceable.sunat_series %>-<%= @dispatch_guide.sourceable.sunat_number %>
            </span>
          </p>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
