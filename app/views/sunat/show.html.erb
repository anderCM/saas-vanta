<% sunat_confirm = "Estas seguro que quieres cambiar esta configuracion? Realizarlo puede generar una discrepancia o errores al momento de generar un documento con SUNAT." %>
<% content_for :page_title, "Facturacion Electronica" %>

<div class="max-w-4xl mx-auto space-y-6">

  <%# ---- Integration status card ---- %>
  <div class="card">
    <h3 class="text-xs font-medium text-muted-foreground uppercase tracking-wide mb-4">Estado de la Integracion</h3>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div class="flex items-center gap-3 p-3 rounded-lg bg-muted/30">
        <% if @enterprise.formal? %>
          <span class="inline-flex items-center justify-center h-8 w-8 rounded-full bg-green-100 dark:bg-green-900/30">
            <svg class="w-4 h-4 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          </span>
          <div>
            <p class="text-sm font-medium text-foreground">RUC registrado</p>
            <p class="text-xs text-muted-foreground font-mono"><%= @enterprise.tax_id %></p>
          </div>
        <% else %>
          <span class="inline-flex items-center justify-center h-8 w-8 rounded-full bg-red-100 dark:bg-red-900/30">
            <svg class="w-4 h-4 text-red-600 dark:text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </span>
          <div>
            <p class="text-sm font-medium text-foreground">Sin RUC</p>
            <p class="text-xs text-muted-foreground">Requerido</p>
          </div>
        <% end %>
      </div>

      <div class="flex items-center gap-3 p-3 rounded-lg bg-muted/30">
        <% if @settings.sunat_api_key.present? %>
          <span class="inline-flex items-center justify-center h-8 w-8 rounded-full bg-green-100 dark:bg-green-900/30">
            <svg class="w-4 h-4 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          </span>
          <div>
            <p class="text-sm font-medium text-foreground">Registrada</p>
            <p class="text-xs text-muted-foreground">Servicio activo</p>
          </div>
        <% else %>
          <span class="inline-flex items-center justify-center h-8 w-8 rounded-full bg-yellow-100 dark:bg-yellow-900/30">
            <svg class="w-4 h-4 text-yellow-600 dark:text-yellow-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01" />
            </svg>
          </span>
          <div>
            <p class="text-sm font-medium text-foreground">Pendiente</p>
            <p class="text-xs text-muted-foreground">Registro requerido</p>
          </div>
        <% end %>
      </div>

      <div class="flex items-center gap-3 p-3 rounded-lg bg-muted/30">
        <% if @settings.sunat_certificate_uploaded? %>
          <span class="inline-flex items-center justify-center h-8 w-8 rounded-full bg-green-100 dark:bg-green-900/30">
            <svg class="w-4 h-4 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          </span>
          <div>
            <p class="text-sm font-medium text-foreground">Certificado</p>
            <p class="text-xs text-muted-foreground">Cargado</p>
          </div>
        <% else %>
          <span class="inline-flex items-center justify-center h-8 w-8 rounded-full bg-yellow-100 dark:bg-yellow-900/30">
            <svg class="w-4 h-4 text-yellow-600 dark:text-yellow-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01" />
            </svg>
          </span>
          <div>
            <p class="text-sm font-medium text-foreground">Certificado</p>
            <p class="text-xs text-muted-foreground">Pendiente</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%# ---- Alert: no RUC ---- %>
  <% unless @enterprise.formal? %>
    <div class="alert-error">
      <p class="text-sm">La empresa debe tener un RUC registrado para emitir comprobantes electronicos.
        <%= link_to "Editar empresa", edit_enterprise_path(@enterprise), class: "underline font-medium" %>.
      </p>
    </div>
  <% end %>

  <% if @enterprise.formal? && policy(@enterprise).manage? %>

    <%# ---- Prerequisites guide (shown when not yet configured) ---- %>
    <% unless @settings.sunat_api_key.present? && @settings.sunat_certificate_uploaded? %>
      <div class="card border-l-4 border-l-primary">
        <div class="flex items-start gap-3 mb-5">
          <div class="flex-shrink-0 mt-0.5">
            <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-foreground">Antes de comenzar</h3>
            <p class="mt-1 text-sm text-muted-foreground">
              Para configurar la facturacion electronica necesitas tener listos estos dos elementos desde el Portal SOL de SUNAT:
            </p>
          </div>
        </div>

        <div class="space-y-4 ml-8">
          <%# Prerequisite 1: Secondary SOL user %>
          <div class="flex items-start gap-3 p-4 rounded-lg bg-muted/40">
            <div class="flex-shrink-0 flex items-center justify-center w-7 h-7 rounded-full bg-primary/10 text-primary text-xs font-bold">1</div>
            <div>
              <h4 class="text-sm font-medium text-foreground">Crear un usuario secundario SOL</h4>
              <p class="mt-1 text-xs text-muted-foreground leading-relaxed">
                Es un usuario adicional que permite a sistemas externos (como VANTA SAAS) emitir comprobantes en nombre de tu empresa, sin usar tu clave principal.
              </p>
              <details class="mt-3 group">
                <summary class="text-xs font-medium text-primary cursor-pointer select-none flex items-center gap-1">
                  <svg class="w-3.5 h-3.5 transition-transform group-open:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                  </svg>
                  Como crearlo paso a paso
                </summary>
                <ol class="mt-2 ml-1 space-y-2 text-xs text-muted-foreground leading-relaxed">
                  <li class="flex gap-2">
                    <span class="font-semibold text-foreground flex-shrink-0">1.</span>
                    Ingresa al <strong class="text-foreground">Portal SOL</strong> de SUNAT con tu RUC, usuario y clave principal.
                  </li>
                  <li class="flex gap-2">
                    <span class="font-semibold text-foreground flex-shrink-0">2.</span>
                    Ve a <strong class="text-foreground">Empresas &rarr; Mis Usuarios Secundarios &rarr; Registro de Usuarios Secundarios</strong>.
                  </li>
                  <li class="flex gap-2">
                    <span class="font-semibold text-foreground flex-shrink-0">3.</span>
                    Haz clic en <strong class="text-foreground">"Crear nuevo usuario"</strong> y completa los datos solicitados.
                  </li>
                  <li class="flex gap-2">
                    <span class="font-semibold text-foreground flex-shrink-0">4.</span>
                    En la seccion de perfiles, asegurate de asignar el perfil <strong class="text-foreground">"Facturador"</strong> para que pueda emitir comprobantes.
                  </li>
                  <li class="flex gap-2">
                    <span class="font-semibold text-foreground flex-shrink-0">5.</span>
                    Guarda el <strong class="text-foreground">usuario y contrasena</strong> que creaste. Los necesitaras en el paso de registro de abajo.
                  </li>
                </ol>
              </details>
            </div>
          </div>

          <%# Prerequisite 2: Digital certificate %>
          <div class="flex items-start gap-3 p-4 rounded-lg bg-muted/40">
            <div class="flex-shrink-0 flex items-center justify-center w-7 h-7 rounded-full bg-primary/10 text-primary text-xs font-bold">2</div>
            <div>
              <h4 class="text-sm font-medium text-foreground">Obtener tu certificado digital SOL</h4>
              <p class="mt-1 text-xs text-muted-foreground leading-relaxed">
                Es un archivo <strong class="text-foreground">.pfx</strong> o <strong class="text-foreground">.p12</strong> que funciona como tu firma digital para validar los comprobantes electronicos ante SUNAT.
              </p>
              <details class="mt-3 group">
                <summary class="text-xs font-medium text-primary cursor-pointer select-none flex items-center gap-1">
                  <svg class="w-3.5 h-3.5 transition-transform group-open:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                  </svg>
                  Como obtenerlo paso a paso
                </summary>
                <ol class="mt-2 ml-1 space-y-2 text-xs text-muted-foreground leading-relaxed">
                  <li class="flex gap-2">
                    <span class="font-semibold text-foreground flex-shrink-0">1.</span>
                    Ingresa al <strong class="text-foreground">Portal SOL</strong> con tu RUC y clave principal.
                  </li>
                  <li class="flex gap-2">
                    <span class="font-semibold text-foreground flex-shrink-0">2.</span>
                    Ve a <strong class="text-foreground">Empresas &rarr; Certificado Digital &rarr; Certificado Digital SOL</strong>.
                  </li>
                  <li class="flex gap-2">
                    <span class="font-semibold text-foreground flex-shrink-0">3.</span>
                    Haz clic en <strong class="text-foreground">"Generar nuevo certificado"</strong>.
                  </li>
                  <li class="flex gap-2">
                    <span class="font-semibold text-foreground flex-shrink-0">4.</span>
                    Crea una <strong class="text-foreground">contrasena para el certificado</strong> y confirma. Guarda esta contrasena, la necesitaras al subir el certificado.
                  </li>
                  <li class="flex gap-2">
                    <span class="font-semibold text-foreground flex-shrink-0">5.</span>
                    Descarga el archivo <strong class="text-foreground">.pfx o .p12</strong> generado y tenlo listo para subirlo aqui.
                  </li>
                </ol>
              </details>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <%# ---- Step 1: Register enterprise ---- %>
    <% unless @settings.sunat_api_key.present? %>
      <div class="card">
        <div class="flex items-start gap-4 mb-6">
          <div class="flex-shrink-0">
            <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center">
              <span class="text-sm font-bold text-primary">1</span>
            </div>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-foreground">Registrar Empresa</h3>
            <p class="mt-1 text-sm text-muted-foreground">
              Ingrese las credenciales SOL de SUNAT para registrar su empresa en el servicio de facturacion.
            </p>
          </div>
        </div>

        <%= form_with url: register_sunat_path, method: :post, class: "space-y-4", data: { turbo_confirm: sunat_confirm } do |f| %>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <%= f.label :sol_user, "Usuario SOL", class: "form-label" %>
              <%= f.text_field :sol_user, class: "form-input", required: true, placeholder: "MODDATOS" %>
            </div>
            <div>
              <%= f.label :sol_password, "Clave SOL", class: "form-label" %>
              <%= f.password_field :sol_password, class: "form-input", required: true %>
            </div>
          </div>
          <%= f.submit "Registrar en SUNAT", class: "btn-primary cursor-pointer" %>
        <% end %>
      </div>
    <% end %>

    <%# ---- Step 2: Upload certificate ---- %>
    <% if @settings.sunat_api_key.present? && !@settings.sunat_certificate_uploaded? %>
      <div class="card">
        <div class="flex items-start gap-4 mb-6">
          <div class="flex-shrink-0">
            <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center">
              <span class="text-sm font-bold text-primary">2</span>
            </div>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-foreground">Subir Certificado Digital</h3>
            <p class="mt-1 text-sm text-muted-foreground">
              Suba su certificado digital (.pfx o .p12) emitido por SUNAT.
            </p>
          </div>
        </div>

        <%= form_with url: upload_certificate_sunat_path, method: :post, multipart: true, class: "space-y-4", data: { turbo_confirm: sunat_confirm } do |f| %>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <%= f.label :certificate, "Certificado (.pfx o .p12)", class: "form-label" %>
              <%= f.file_field :certificate, class: "block w-full text-sm text-muted-foreground file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-primary/10 file:text-primary hover:file:bg-primary/20 file:cursor-pointer", required: true, accept: ".pfx,.p12" %>
            </div>
            <div>
              <%= f.label :certificate_password, "Clave del certificado", class: "form-label" %>
              <%= f.password_field :certificate_password, class: "form-input", required: true %>
            </div>
          </div>
          <%= f.submit "Subir Certificado", class: "btn-primary cursor-pointer" %>
        <% end %>
      </div>
    <% end %>

    <%# ---- Configured state: Series & credentials ---- %>
    <% if @settings.sunat_api_key.present? %>

      <%# ---- Series configuration (unified card) ---- %>
      <div class="card">
        <h3 class="text-sm font-semibold text-foreground">Series y Correlativos</h3>
        <p class="mt-1 text-sm text-muted-foreground mb-6">
          Configure la serie y correlativo para cada tipo de comprobante electronico.
        </p>

        <% unless @enterprise.ubigeo.present? %>
          <div class="alert-warning mb-6">
            <p class="text-sm">
              La empresa no tiene ubigeo asignado. Configurelo en
              <%= link_to "Editar Empresa", edit_enterprise_path(@enterprise), class: "underline font-medium" %>.
            </p>
          </div>
        <% end %>

        <%= form_with model: @settings, url: update_settings_sunat_path, method: :patch, class: "space-y-0", data: { turbo_confirm: sunat_confirm } do |f| %>
          <div class="divide-y divide-border -mx-5">
            <%# Factura %>
            <div class="px-5 py-4">
              <div class="flex flex-col sm:flex-row sm:items-center gap-4">
                <div class="sm:w-40 flex-shrink-0">
                  <p class="text-sm font-medium text-foreground">Factura</p>
                  <p class="text-xs text-muted-foreground">Clientes con RUC</p>
                </div>
                <div class="flex-1 grid grid-cols-2 gap-4">
                  <div>
                    <%= f.label :sunat_series_factura, "Serie", class: "form-label" %>
                    <%= f.text_field :sunat_series_factura, class: "form-input font-mono", placeholder: "F001", maxlength: 4 %>
                  </div>
                  <div>
                    <%= f.label :sunat_next_factura_number, "Correlativo", class: "form-label" %>
                    <%= f.number_field :sunat_next_factura_number, class: "form-input tabular-nums", placeholder: "1", min: 1 %>
                  </div>
                </div>
              </div>
            </div>

            <%# Boleta %>
            <div class="px-5 py-4">
              <div class="flex flex-col sm:flex-row sm:items-center gap-4">
                <div class="sm:w-40 flex-shrink-0">
                  <p class="text-sm font-medium text-foreground">Boleta</p>
                  <p class="text-xs text-muted-foreground">Clientes con DNI</p>
                </div>
                <div class="flex-1 grid grid-cols-2 gap-4">
                  <div>
                    <%= f.label :sunat_series_boleta, "Serie", class: "form-label" %>
                    <%= f.text_field :sunat_series_boleta, class: "form-input font-mono", placeholder: "B001", maxlength: 4 %>
                  </div>
                  <div>
                    <%= f.label :sunat_next_boleta_number, "Correlativo", class: "form-label" %>
                    <%= f.number_field :sunat_next_boleta_number, class: "form-input tabular-nums", placeholder: "1", min: 1 %>
                  </div>
                </div>
              </div>
            </div>

            <%# GRR %>
            <div class="px-5 py-4">
              <div class="flex flex-col sm:flex-row sm:items-center gap-4">
                <div class="sm:w-40 flex-shrink-0">
                  <p class="text-sm font-medium text-foreground">Guia Remitente</p>
                  <p class="text-xs text-muted-foreground">GRR</p>
                </div>
                <div class="flex-1 grid grid-cols-2 gap-4">
                  <div>
                    <%= f.label :sunat_series_grr, "Serie", class: "form-label" %>
                    <%= f.text_field :sunat_series_grr, class: "form-input font-mono", placeholder: "T001", maxlength: 4 %>
                  </div>
                  <div>
                    <%= f.label :sunat_next_grr_number, "Correlativo", class: "form-label" %>
                    <%= f.number_field :sunat_next_grr_number, class: "form-input tabular-nums", placeholder: "1", min: 1 %>
                  </div>
                </div>
              </div>
            </div>

            <%# GRT %>
            <div class="px-5 py-4">
              <div class="flex flex-col sm:flex-row sm:items-center gap-4">
                <div class="sm:w-40 flex-shrink-0">
                  <p class="text-sm font-medium text-foreground">Guia Transportista</p>
                  <p class="text-xs text-muted-foreground">GRT</p>
                </div>
                <div class="flex-1 grid grid-cols-2 gap-4">
                  <div>
                    <%= f.label :sunat_series_grt, "Serie", class: "form-label" %>
                    <%= f.text_field :sunat_series_grt, class: "form-input font-mono", placeholder: "V001", maxlength: 4 %>
                  </div>
                  <div>
                    <%= f.label :sunat_next_grt_number, "Correlativo", class: "form-label" %>
                    <%= f.number_field :sunat_next_grt_number, class: "form-input tabular-nums", placeholder: "1", min: 1 %>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="flex justify-end pt-5">
            <%= f.submit "Guardar Series", class: "btn-primary cursor-pointer" %>
          </div>
        <% end %>
      </div>

      <%# ---- Credentials & Certificate ---- %>
      <div class="card">
        <h3 class="text-sm font-semibold text-foreground mb-6">Credenciales y Certificado</h3>

        <div class="divide-y divide-border -mx-5">
          <%# SOL Credentials %>
          <div class="px-5 py-4">
            <h4 class="text-sm font-medium text-foreground mb-1">Credenciales SOL</h4>
            <p class="text-xs text-muted-foreground mb-4">Actualice su usuario y clave SOL de SUNAT.</p>

            <%= form_with url: update_sol_credentials_sunat_path, method: :patch, class: "space-y-4", data: { turbo_confirm: sunat_confirm } do |f| %>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <%= f.label :sol_user, "Usuario SOL", class: "form-label" %>
                  <%= f.text_field :sol_user, value: @settings.sunat_sol_user, class: "form-input", required: true, placeholder: "MODDATOS" %>
                </div>
                <div>
                  <%= f.label :sol_password, "Clave SOL", class: "form-label" %>
                  <%= f.password_field :sol_password, class: "form-input", required: true %>
                </div>
              </div>
              <div class="flex justify-end">
                <%= f.submit "Actualizar Credenciales", class: "btn-secondary cursor-pointer" %>
              </div>
            <% end %>
          </div>

          <%# SUNAT REST API Credentials (for dispatch guides) %>
          <div class="px-5 py-4">
            <h4 class="text-sm font-medium text-foreground mb-1">Credenciales API REST SUNAT</h4>
            <p class="text-xs text-muted-foreground mb-4">
              Requeridas para emitir Guias de Remision. Obtenga estas credenciales desde el Portal SOL de SUNAT
              en <strong class="text-foreground">Menu SOL &rarr; Empresa &rarr; Gestión Credenciales de API SUNAT</strong>.
            </p>

            <% if @settings.sunat_client_id.present? %>
              <div class="flex items-center gap-2 mb-4">
                <span class="inline-flex items-center justify-center h-5 w-5 rounded-full bg-green-100 dark:bg-green-900/30">
                  <svg class="w-3 h-3 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                </span>
                <span class="text-xs text-green-700 dark:text-green-400 font-medium">Credenciales configuradas</span>
              </div>
            <% end %>

            <%= form_with url: update_sunat_rest_credentials_sunat_path, method: :patch, class: "space-y-4", data: { turbo_confirm: sunat_confirm } do |f| %>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <%= f.label :sunat_client_id, "Client ID", class: "form-label" %>
                  <%= f.text_field :sunat_client_id, value: @settings.sunat_client_id, class: "form-input font-mono", required: true %>
                </div>
                <div>
                  <%= f.label :sunat_client_secret, "Client Secret", class: "form-label" %>
                  <%= f.password_field :sunat_client_secret, class: "form-input", required: true %>
                </div>
              </div>
              <div class="flex justify-end">
                <%= f.submit "Actualizar Credenciales REST", class: "btn-secondary cursor-pointer" %>
              </div>
            <% end %>
          </div>

          <%# Certificate %>
          <% if @settings.sunat_certificate_uploaded? %>
            <div class="px-5 py-4">
              <h4 class="text-sm font-medium text-foreground mb-1">Certificado Digital</h4>
              <p class="text-xs text-muted-foreground mb-4">Actualice su certificado digital (.pfx o .p12) si es necesario.</p>

              <%= form_with url: upload_certificate_sunat_path, method: :post, multipart: true, class: "space-y-4", data: { turbo_confirm: sunat_confirm } do |f| %>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <div>
                    <%= f.label :certificate, "Certificado (.pfx o .p12)", class: "form-label" %>
                    <%= f.file_field :certificate, class: "block w-full text-sm text-muted-foreground file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-primary/10 file:text-primary hover:file:bg-primary/20 file:cursor-pointer", required: true, accept: ".pfx,.p12" %>
                  </div>
                  <div>
                    <%= f.label :certificate_password, "Clave del certificado", class: "form-label" %>
                    <%= f.password_field :certificate_password, class: "form-input", required: true %>
                  </div>
                </div>
                <div class="flex justify-end">
                  <%= f.submit "Actualizar Certificado", class: "btn-secondary cursor-pointer" %>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>

    <% end %>
  <% end %>

  <%# ---- Security disclaimer (always visible) ---- %>
