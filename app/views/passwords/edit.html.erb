<div class="min-h-screen flex items-center justify-center bg-background p-6">
  <button
    id="theme-toggle"
    class="absolute top-6 right-6 theme-toggle z-10"
    aria-label="Cambiar tema"
  >
    <svg id="sun-icon" class="hidden w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
    </svg>
    <svg id="moon-icon" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
    </svg>
  </button>

  <div class="w-full max-w-sm">
    <div class="flex flex-col items-center mb-8">
      <img src="/logo-vanta.png" alt="VANTA" class="h-12 w-auto mb-6">
      <h1 class="text-xl font-semibold text-foreground">Nueva contrasena</h1>
      <p class="mt-1 text-sm text-muted-foreground">Ingresa tu nueva contrasena para continuar</p>
    </div>

    <%= render "shared/flash_messages" %>

    <div class="card">
      <%= form_with url: password_path(params[:token]), method: :put, class: "space-y-5" do |form| %>
        <%= render "shared/password_field",
            form: form,
            field: :password,
            label: "Nueva contrasena",
            autofocus: true,
            autocomplete: "new-password" %>

        <%= render "shared/password_field",
            form: form,
            field: :password_confirmation,
            label: "Confirmar contrasena",
            autocomplete: "new-password" %>

        <div>
          <%= form.submit "Actualizar contrasena", class: "w-full btn-primary h-11 cursor-pointer" %>
        </div>
      <% end %>
    </div>

    <div class="mt-6 text-center">
      <%= link_to login_path, class: "inline-flex items-center gap-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors" do %>
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Volver al inicio de sesion
      <% end %>
    </div>
  </div>
</div>
