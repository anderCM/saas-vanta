<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "VANTA SAAS" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="VANTA SAAS">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/logo-vanta-fox.png" type="image/png">
    <link rel="apple-touch-icon" href="/logo-vanta-fox.png">

    <%# Google Fonts - Inter %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= enterprise_custom_colors_tag if defined?(current_enterprise) && current_enterprise %>
    <%= combobox_style_tag %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="antialiased">
    <%# Theme initialization - default to light %>
    <script>
      (function() {
        const theme = localStorage.getItem('theme') || 'light';
        if (theme === 'dark') {
          document.body.classList.add('dark');
        }
      })();
    </script>

    <% if authenticated? %>
      <%# Authenticated Layout with Sidebar %>
      <div data-controller="main-content" data-action="sidebar:collapsed->main-content#collapse sidebar:expanded->main-content#expand sidebar:mobileOpen->main-content#showOverlay sidebar:mobileClosed->main-content#hideOverlay">
        <%# Mobile Overlay %>
        <div class="sidebar-overlay" data-main-content-target="overlay" data-action="click->main-content#closeSidebar"></div>

        <%= render "shared/sidebar" %>

        <main class="main-with-sidebar" data-main-content-target="content">
          <%# Dashboard Header %>
          <header class="dashboard-header">
            <div class="flex items-center justify-between w-full">
              <div class="flex items-center gap-3">
                <%# Mobile Menu Button %>
                <button type="button" class="mobile-menu-btn" data-action="click->main-content#openSidebar" title="Abrir menú">
                  <%= sidebar_icon("menu", class: "w-6 h-6") %>
                </button>
                <div>
                  <% if breadcrumb_items.any? %>
                    <%= render "shared/breadcrumbs" %>
                  <% end %>
                  <h1 class="dashboard-header-title"><%= content_for(:page_title) || "Dashboard" %></h1>
                </div>
              </div>

              <%# Beta badge + Sugerir mejoras %>
              <div class="hidden sm:flex flex-col items-end gap-0.5 shrink-0">
                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-[10px] font-semibold uppercase tracking-wider bg-warning/15 text-warning border border-warning/25">
                  <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                  Beta
                </span>
                <%= link_to new_suggestion_path, class: "text-[11px] text-muted-foreground hover:text-primary transition-colors" do %>
                  Sugerir mejoras
                <% end %>
              </div>
            </div>
          </header>

          <%# Main Content %>
          <div class="dashboard-content">
            <%# Flash messages as toasts %>
            <% flash.each do |key, value| %>
              <script>
                document.addEventListener("turbo:load", function handler() {
                  showToast("<%= j(value) %>", "<%= key == 'notice' ? 'success' : 'error' %>");
                  document.removeEventListener("turbo:load", handler);
                }, { once: true });
                // Also fire immediately for non-Turbo loads
                if (document.readyState === "complete") {
                  showToast("<%= j(value) %>", "<%= key == 'notice' ? 'success' : 'error' %>");
                }
              </script>
            <% end %>

            <%= yield %>
          </div>
        </main>
      </div>
    <% else %>
      <%# Public Layout (Login, etc.) %>
      <main class="min-h-screen bg-background">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
          <%# Flash Messages %>
          <% flash.each do |key, value| %>
            <div class="<%= key == 'notice' ? 'alert-success' : 'alert-error' %> mb-6" role="alert">
              <span class="block sm:inline"><%= value %></span>
            </div>
          <% end %>

          <%= yield %>
        </div>
      </main>
    <% end %>

    <%# Theme toggle functionality %>
    <script>
      function initTheme() {
        const theme = localStorage.getItem('theme') || 'light';
        if (theme === 'dark') {
          document.body.classList.add('dark');
        } else {
          document.body.classList.remove('dark');
        }
        updateThemeUI();
      }

      function toggleTheme() {
        const isDark = document.body.classList.contains('dark');
        if (isDark) {
          document.body.classList.remove('dark');
          localStorage.setItem('theme', 'light');
        } else {
          document.body.classList.add('dark');
          localStorage.setItem('theme', 'dark');
        }
        updateThemeUI();
      }

      function updateThemeUI() {
        const isDark = document.body.classList.contains('dark');

        // Toggle icons
        document.querySelectorAll('.theme-icon-dark').forEach(el => {
          el.classList.toggle('hidden', isDark);
        });
        document.querySelectorAll('.theme-icon-light').forEach(el => {
          el.classList.toggle('hidden', !isDark);
        });

        // Toggle text
        document.querySelectorAll('.theme-text-dark').forEach(el => {
          el.classList.toggle('hidden', isDark);
        });
        document.querySelectorAll('.theme-text-light').forEach(el => {
          el.classList.toggle('hidden', !isDark);
        });
      }

      document.addEventListener('DOMContentLoaded', () => {
        initTheme();
        document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme);
      });

      // Also run on turbo:load for Turbo Drive navigation
      document.addEventListener('turbo:load', () => {
        initTheme();
        document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme);
      });

      initTheme();
    </script>

    <script>
      (function() {
        var isMobile = window.innerWidth <= 768;
        if (!isMobile) {
          var isCollapsed = localStorage.getItem('sidebarCollapsed') === 'true';
          if (isCollapsed) {
            var mainContent = document.querySelector('.main-with-sidebar');
            var sidebar = document.querySelector('.sidebar');
            if (mainContent) mainContent.classList.add('sidebar-is-collapsed');
            if (sidebar) sidebar.classList.add('sidebar-collapsed');
          }
        }
      })();
    </script>

    <%= render "shared/support_widget" %>

    <div data-controller="toast" data-toast-position-value="bottom-right" class="fixed bottom-20 right-4 z-50 flex flex-col gap-2 max-w-sm">
      <div data-toast-target="container" class="flex flex-col gap-2"></div>
    </div>

    <dialog id="modal-dialog"
            data-controller="modal"
            data-action="click->modal#backdropClose turbo:submit-end->modal#onSubmitEnd"
            class="backdrop:bg-black/50 backdrop:backdrop-blur-sm bg-card text-card-foreground rounded-xl shadow-2xl border border-border max-w-lg w-[calc(100%-2rem)] p-0 fixed inset-0 m-auto h-fit open:flex open:flex-col">
      <%= turbo_frame_tag "modal" %>
    </dialog>
  </body>
</html>
