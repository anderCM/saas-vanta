<% content_for :page_title, "Ventas" %>

<div class="max-w-7xl mx-auto">
  <div class="flex items-center justify-end gap-3 mb-6">
    <% if policy(Sale).create? %>
      <%= link_to new_sale_path, class: "btn-primary" do %>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
        </svg>
        Nueva Venta
      <% end %>
    <% end %>
  </div>

  <% if @sales.any? %>
    <div class="card overflow-hidden p-0">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-border">
          <thead>
            <tr class="bg-muted/40">
              <th class="table-th text-left">Codigo</th>
              <th class="table-th text-left">Cliente</th>
              <th class="table-th text-left">Vendedor</th>
              <th class="table-th text-left">Fecha</th>
              <th class="table-th text-right">Total</th>
              <th class="table-th text-center">Estado</th>
              <th class="table-th"><span class="sr-only">Acciones</span></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border">
            <% @sales.each do |sale| %>
              <tr class="hover:bg-muted/30 transition-colors">
                <td class="px-5 py-3.5 whitespace-nowrap">
                  <span class="text-sm font-medium text-foreground font-mono"><%= sale.code %></span>
                </td>
                <td class="px-5 py-3.5 whitespace-nowrap">
                  <span class="text-sm font-medium text-foreground"><%= sale.customer.name %></span>
                </td>
                <td class="px-5 py-3.5 whitespace-nowrap">
                  <span class="text-sm text-muted-foreground"><%= sale.seller.first_name %></span>
                </td>
                <td class="px-5 py-3.5 whitespace-nowrap">
                  <span class="text-sm text-muted-foreground"><%= l(sale.issue_date, format: :short) %></span>
                </td>
                <td class="px-5 py-3.5 whitespace-nowrap text-right">
                  <span class="text-sm font-medium text-foreground tabular-nums">S/ <%= number_with_precision(sale.total, precision: 2, delimiter: ",") %></span>
                </td>
                <td class="px-5 py-3.5 whitespace-nowrap text-center">
                  <span class="<%= sale.status_badge_class %>"><%= sale.status_label %></span>
                </td>
                <td class="px-5 py-3.5 whitespace-nowrap text-right">
                  <div class="flex items-center justify-end gap-1">
                    <%= link_to sale, class: "table-action-btn", title: "Ver" do %>
                      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                      </svg>
                    <% end %>
                    <% if sale.can_edit? && policy(sale).update? %>
                      <%= link_to edit_sale_path(sale), class: "table-action-btn", title: "Editar" do %>
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                        </svg>
                      <% end %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @pagy.pages > 1 %>
        <div class="px-5 py-3.5 border-t border-border">
          <%= render "shared/table/pagination", pagy: @pagy %>
        </div>
      <% end %>
    </div>
  <% else %>
    <%= render "shared/table/empty_state",
      icon: :document,
      title: "No hay ventas",
      description: "Comienza creando tu primera venta.",
      action_path: new_sale_path,
      action_label: "Nueva Venta",
      show_action: policy(Sale).create? %>
  <% end %>
</div>
