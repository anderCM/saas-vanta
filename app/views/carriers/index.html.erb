<% content_for :page_title, "Transportistas" %>

<div class="max-w-7xl mx-auto">
  <div class="flex items-center justify-end gap-3 mb-6">
    <% if policy(Carrier).create? %>
      <%= link_to new_carrier_path, class: "btn-primary inline-flex items-center gap-2" do %>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
        </svg>
        Nuevo Transportista
      <% end %>
    <% end %>
  </div>

  <% if @carriers.any? %>
    <div class="card overflow-hidden p-0">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-border">
          <thead class="bg-muted/40">
            <tr>
              <th class="table-th text-left">RUC</th>
              <th class="table-th text-left">Nombre</th>
              <th class="table-th text-left">Estado</th>
              <th class="table-th"><span class="sr-only">Acciones</span></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border">
            <% @carriers.each do |carrier| %>
              <tr class="hover:bg-muted/30 transition-colors">
                <td class="px-5 py-3.5 whitespace-nowrap text-sm font-medium text-foreground"><%= carrier.ruc %></td>
                <td class="px-5 py-3.5 whitespace-nowrap text-sm text-foreground"><%= carrier.name %></td>
                <td class="px-5 py-3.5 whitespace-nowrap">
                  <span class="<%= carrier.active? ? 'badge-success' : 'badge-secondary' %>"><%= carrier.active? ? 'Activo' : 'Inactivo' %></span>
                </td>
                <td class="px-5 py-3.5 whitespace-nowrap text-right text-sm font-medium">
                  <div class="flex items-center justify-end gap-1">
                    <% if policy(carrier).update? %>
                      <%= link_to edit_carrier_path(carrier), class: "table-action-btn", title: "Editar" do %>
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                        </svg>
                      <% end %>
                    <% end %>
                    <% if policy(carrier).destroy? %>
                      <%= button_to carrier, method: :delete, class: "table-action-btn-danger", title: "Eliminar", data: { turbo_confirm: "Estas seguro de eliminar este transportista?" } do %>
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                        </svg>
                      <% end %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @pagy.pages > 1 %>
        <div class="px-5 py-3.5 border-t border-border bg-muted/30">
          <%= render "shared/table/pagination", pagy: @pagy %>
        </div>
      <% end %>
    </div>
  <% else %>
    <%= render "shared/table/empty_state",
      icon: :truck,
      title: "No hay transportistas",
      description: "Comienza registrando tu primer transportista.",
      action_path: new_carrier_path,
      action_label: "Nuevo Transportista",
      show_action: policy(Carrier).create? %>
  <% end %>
</div>
