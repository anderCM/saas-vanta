<% content_for :page_title, @product.name %>

<div class="max-w-5xl mx-auto space-y-6">
  <%# Header %>
  <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4">
    <div class="space-y-1">
      <div class="flex items-center gap-3">
        <h1 class="text-xl font-semibold text-foreground"><%= @product.name %></h1>
        <% if @product.service? %>
          <span class="badge-info">Servicio</span>
        <% end %>
        <%= render_status_badge(@product.status) %>
      </div>
      <p class="text-sm text-muted-foreground">
        <% if @product.sku.present? %>
          <span class="font-mono">SKU: <%= @product.sku %></span> &middot;
        <% end %>
        Creado <%= time_ago_in_words(@product.created_at) %> atras
      </p>
    </div>
    <div class="flex flex-wrap gap-2">
      <%= link_to "Volver", products_path(product_type: @product.product_type), class: "btn-secondary" %>
      <% if policy(@product).edit? %>
        <%= link_to "Editar", edit_product_path(@product), class: "btn-secondary" %>
      <% end %>
    </div>
  </div>

  <%# Info Cards %>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
    <div class="lg:col-span-2 space-y-4">
      <div class="card">
        <h3 class="text-xs font-medium text-muted-foreground uppercase tracking-wide mb-2">Informacion General</h3>
        <dl class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <dt class="text-xs text-muted-foreground">Nombre</dt>
            <dd class="text-sm font-medium text-foreground mt-0.5"><%= @product.name %></dd>
          </div>
          <div>
            <dt class="text-xs text-muted-foreground">SKU</dt>
            <dd class="text-sm font-medium text-foreground mt-0.5 font-mono"><%= @product.sku.presence || "-" %></dd>
          </div>
          <div>
            <dt class="text-xs text-muted-foreground">Tipo de Origen</dt>
            <dd class="text-sm font-medium text-foreground mt-0.5"><%= source_type_label(@product.source_type) %></dd>
          </div>
          <div>
            <dt class="text-xs text-muted-foreground">Unidad de Medida</dt>
            <dd class="text-sm font-medium text-foreground mt-0.5"><%= unit_label(@product.unit) %></dd>
          </div>
          <% if @product.capacity_label.present? %>
            <div>
              <dt class="text-xs text-muted-foreground">Capacidad</dt>
              <dd class="text-sm font-medium text-foreground mt-0.5"><%= @product.capacity_label %></dd>
            </div>
          <% end %>
          <% if @product.units_per_package.present? %>
            <div>
              <dt class="text-xs text-muted-foreground">Unidades por Paquete</dt>
              <dd class="text-sm font-medium text-foreground mt-0.5"><%= @product.units_per_package %></dd>
            </div>
          <% end %>
          <% if @product.provider.present? %>
            <div>
              <dt class="text-xs text-muted-foreground">Proveedor</dt>
              <dd class="text-sm font-medium text-foreground mt-0.5"><%= @product.provider.name %></dd>
            </div>
          <% end %>
        </dl>
        <% if @product.description.present? %>
          <div class="mt-4 pt-4 border-t border-border">
            <dt class="text-xs text-muted-foreground">Descripcion</dt>
            <dd class="text-sm text-foreground mt-0.5"><%= @product.description %></dd>
          </div>
        <% end %>
      </div>

      <div class="card">
        <h3 class="text-xs font-medium text-muted-foreground uppercase tracking-wide mb-2">Precios</h3>
        <dl class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div class="p-3 bg-muted/30 rounded-lg">
            <dt class="text-xs text-muted-foreground">Precio de Compra</dt>
            <dd class="text-lg font-semibold text-foreground mt-0.5 tabular-nums">S/ <%= number_with_precision(@product.buy_price, precision: 2) %></dd>
          </div>
          <div class="p-3 bg-muted/30 rounded-lg">
            <dt class="text-xs text-muted-foreground">Precio Venta Contado</dt>
            <dd class="text-lg font-semibold text-primary mt-0.5 tabular-nums">S/ <%= number_with_precision(@product.sell_cash_price, precision: 2) %></dd>
          </div>
          <div class="p-3 bg-muted/30 rounded-lg">
            <dt class="text-xs text-muted-foreground">Precio Venta Credito</dt>
            <dd class="text-lg font-semibold text-foreground mt-0.5 tabular-nums">S/ <%= number_with_precision(@product.sell_credit_price, precision: 2) %></dd>
          </div>
        </dl>
      </div>
    </div>

    <div class="space-y-4">
      <% if current_enterprise.use_stock? && !@product.service? %>
        <div class="card">
          <h3 class="text-xs font-medium text-muted-foreground uppercase tracking-wide mb-2">Inventario</h3>
          <div class="text-center p-3 bg-muted/30 rounded-lg">
            <span class="text-2xl font-bold text-foreground tabular-nums"><%= @product.stock.presence || 0 %></span>
            <span class="text-sm text-muted-foreground ml-1"><%= @product.unit %></span>
            <p class="text-xs text-muted-foreground mt-0.5">en stock</p>
          </div>
        </div>
      <% end %>

      <% if policy(@product).destroy? %>
        <div class="card">
          <h3 class="text-xs font-medium text-muted-foreground uppercase tracking-wide mb-2">Zona de Peligro</h3>
          <%= button_to "Eliminar Producto",
              @product,
              method: :delete,
              class: "w-full btn-destructive",
              data: { turbo_confirm: "Estas seguro de eliminar este producto? Esta accion no se puede deshacer." } %>
        </div>
      <% end %>
    </div>
  </div>
</div>
