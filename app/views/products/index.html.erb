<% content_for :page_title, "Productos" %>
<% add_breadcrumb "Catalogo" %>
<% add_breadcrumb "Productos" %>

<div class="max-w-7xl mx-auto">
  <div class="flex items-center justify-between gap-3 mb-6">
    <div class="w-full max-w-sm">
      <%= render "shared/table/search_bar", url: products_path, placeholder: "Buscar por nombre o SKU...", extra_params: { product_type: @product_type } %>
    </div>
    <div class="flex items-center gap-3">
    <% if policy(Product).create? %>
      <%= link_to new_bulk_import_path(resource_type: "Product"), class: "btn-secondary inline-flex items-center gap-2" do %>
        <%= app_icon("cloud-upload", class: "w-4 h-4") %>
        Importar
      <% end %>
      <%= link_to new_product_path(product_type: @product_type), class: "btn-primary inline-flex items-center gap-2" do %>
        <%= app_icon("plus", class: "w-4 h-4") %>
        Agregar <%= @product_type == "service" ? "Servicio" : "Producto" %>
      <% end %>
    <% end %>
    </div>
  </div>

  <%# Tabs - solo mostrar si hay más de un tipo habilitado %>
  <% has_products = current_enterprise.sells_products? %>
  <% has_services = current_enterprise.sells_services? %>
  <% if has_products && has_services %>
    <div class="border-b border-border mb-6">
      <nav class="-mb-px flex space-x-8">
        <%= link_to products_path(product_type: "good"),
                    class: "tab-link #{@product_type == 'good' ? 'tab-link-active' : ''}" do %>
          Productos
        <% end %>
        <%= link_to products_path(product_type: "service"),
                    class: "tab-link #{@product_type == 'service' ? 'tab-link-active' : ''}" do %>
          Servicios
        <% end %>
      </nav>
    </div>
  <% end %>

  <% if @products.any? %>
    <div class="card overflow-hidden p-0">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-border">
          <thead class="bg-muted/40">
            <tr>
              <th class="table-th text-left">Producto</th>
              <th class="table-th text-left">SKU</th>
              <th class="table-th text-left">Origen</th>
              <th class="table-th text-right">P. Compra</th>
              <th class="table-th text-right">P. Venta</th>
              <% if current_enterprise.use_stock? %>
                <th class="table-th text-center">Stock</th>
              <% end %>
              <th class="table-th text-center">Estado</th>
              <th class="table-th"><span class="sr-only">Acciones</span></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border">
            <% @products.each do |product| %>
              <tr class="hover:bg-muted/30 transition-colors">
                <%= table_cell_primary(product.name, product.provider&.name, product) %>
                <%= table_cell_code(product.sku) %>
                <%= table_cell(source_type_label(product.source_type)) %>
                <%= table_cell(product.buy_price, type: :currency, align: :right, class: "text-muted-foreground") %>
                <%= table_cell(product.sell_cash_price, type: :currency, align: :right, class: "font-medium text-foreground") %>
                <% if current_enterprise.use_stock? %>
                  <%= table_cell_stock(product.stock, product.unit) %>
                <% end %>
                <td class="px-5 py-3.5 whitespace-nowrap text-center">
                  <%= render_status_badge(product.status) %>
                </td>
                <td class="px-5 py-3.5 whitespace-nowrap text-right text-sm font-medium">
                  <div class="flex items-center justify-end gap-1">
                    <%= link_to product, class: "table-action-btn", title: "Ver" do %>
                      <%= app_icon("eye", class: "w-4 h-4") %>
                    <% end %>
                    <% if policy(product).edit? %>
                      <%= link_to edit_product_path(product), class: "table-action-btn", title: "Editar" do %>
                        <%= app_icon("pencil", class: "w-4 h-4") %>
                      <% end %>
                    <% end %>
                    <% if policy(product).destroy? %>
                      <%= button_to product, method: :delete, class: "table-action-btn-danger", title: "Eliminar", data: { turbo_confirm: "¿Estás seguro de eliminar este producto?" } do %>
                        <%= app_icon("trash", class: "w-4 h-4") %>
                      <% end %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <% if @pagy.pages > 1 %>
        <div class="px-5 py-3.5 border-t border-border">
          <%= render "shared/table/pagination", pagy: @pagy %>
        </div>
      <% end %>
    </div>
  <% else %>
    <% if @product_type == "service" %>
      <%= render "shared/table/empty_state",
        icon: :box,
        title: "No hay servicios",
        description: "Comienza agregando tu primer servicio.",
        action_path: new_product_path(product_type: "service"),
        action_label: "Nuevo Servicio",
        show_action: policy(Product).create? %>
    <% else %>
      <%= render "shared/table/empty_state",
        icon: :box,
        title: "No hay productos",
        description: "Comienza agregando tu primer producto.",
        action_path: new_product_path(product_type: "good"),
        action_label: "Nuevo Producto",
        show_action: policy(Product).create? %>
    <% end %>
  <% end %>
</div>
