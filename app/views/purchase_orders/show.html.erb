<% content_for :page_title, @purchase_order.code %>

<div class="max-w-5xl mx-auto space-y-6">
  <%# Header %>
  <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4">
    <div class="space-y-3">
      <h1 class="text-xl font-semibold text-foreground font-mono"><%= @purchase_order.code %></h1>
      <p class="text-sm text-muted-foreground">
        Creada por <%= @purchase_order.created_by.first_name %> el <%= l(@purchase_order.created_at, format: :long) %>
      </p>
      <%= render "shared/documents/status_bar",
          steps: [
            { key: "draft", label: "Borrador" },
            { key: "confirmed", label: "Confirmada" },
            { key: "received", label: "Recibida" }
          ],
          current: @purchase_order.status,
          cancelled: @purchase_order.cancelled? %>
    </div>
    <div class="flex flex-wrap gap-2">
      <%= link_to "Volver", purchase_orders_path, class: "btn-secondary" %>
      <%= link_to "PDF", pdf_purchase_order_path(@purchase_order), class: "btn-secondary", data: { turbo: false } %>

      <% if @purchase_order.can_edit? && policy(@purchase_order).update? %>
        <%= link_to "Editar", edit_purchase_order_path(@purchase_order), class: "btn-secondary" %>
      <% end %>

      <% if @purchase_order.can_confirm? && policy(@purchase_order).confirm? %>
        <%= button_to "Confirmar", confirm_purchase_order_path(@purchase_order),
            method: :patch, class: "btn-primary",
            data: { turbo_confirm: "Confirmar esta orden? Una vez confirmada no podra editarse." } %>
      <% end %>

      <% if @purchase_order.can_receive? && policy(@purchase_order).receive? %>
        <%= button_to "Marcar Recibida", receive_purchase_order_path(@purchase_order),
            method: :patch, class: "btn-success",
            data: { turbo_confirm: "Marcar como recibida? Esto actualizara el stock de los productos." } %>
      <% end %>

      <% if @purchase_order.can_cancel? && policy(@purchase_order).cancel? %>
        <%= button_to "Cancelar", cancel_purchase_order_path(@purchase_order),
            method: :patch, class: "btn-destructive",
            data: { turbo_confirm: "Cancelar esta orden? Esta accion no se puede deshacer." } %>
      <% end %>
    </div>
  </div>

  <%# Info Cards %>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
    <div class="card">
      <h3 class="text-xs font-medium text-muted-foreground uppercase tracking-wide mb-2">Proveedor</h3>
      <p class="text-sm font-semibold text-foreground"><%= @purchase_order.provider.name %></p>
      <% if @purchase_order.provider.tax_id.present? %>
        <p class="text-xs text-muted-foreground mt-0.5">RUC: <%= @purchase_order.provider.tax_id %></p>
      <% end %>
    </div>

    <div class="card">
      <h3 class="text-xs font-medium text-muted-foreground uppercase tracking-wide mb-2">Fechas</h3>
      <p class="text-sm text-foreground"><span class="font-medium">Emision:</span> <%= l(@purchase_order.issue_date, format: :long) %></p>
      <% if @purchase_order.expected_date.present? %>
        <p class="text-sm text-foreground"><span class="font-medium">Esperada:</span> <%= l(@purchase_order.expected_date, format: :long) %></p>
      <% end %>
    </div>

    <div class="card">
      <h3 class="text-xs font-medium text-muted-foreground uppercase tracking-wide mb-2">Destino</h3>
      <p class="text-sm text-foreground"><%= @purchase_order.destination&.full_path || "No especificado" %></p>
    </div>
  </div>

  <% if @purchase_order.sourceable.is_a?(Sale) %>
    <div class="card">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <h3 class="text-xs font-medium text-muted-foreground uppercase tracking-wide mb-2">Origen</h3>
          <p class="text-sm text-foreground">
            Generada desde venta
            <%= link_to @purchase_order.sourceable.code, sale_path(@purchase_order.sourceable), class: "link-primary font-medium font-mono" %>
          </p>
        </div>
        <div>
          <h3 class="text-xs font-medium text-muted-foreground uppercase tracking-wide mb-2">Cliente (Entrega)</h3>
          <p class="text-sm font-medium text-foreground"><%= @purchase_order.sourceable.customer.name %></p>
          <% if @purchase_order.delivery_address.present? %>
            <p class="text-xs text-muted-foreground mt-0.5"><%= @purchase_order.delivery_address %></p>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <%# Items Table %>
  <div class="card p-0">
    <div class="px-5 py-4 border-b border-border">
      <h3 class="text-sm font-semibold text-foreground">Items</h3>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-border">
        <thead>
          <tr class="bg-muted/40">
            <th class="px-5 py-2.5 text-left text-xs font-medium text-muted-foreground uppercase w-10">#</th>
            <th class="px-5 py-2.5 text-left text-xs font-medium text-muted-foreground uppercase">Producto</th>
            <th class="px-5 py-2.5 text-right text-xs font-medium text-muted-foreground uppercase">Cantidad</th>
            <th class="px-5 py-2.5 text-right text-xs font-medium text-muted-foreground uppercase">Precio Unit.</th>
            <th class="px-5 py-2.5 text-right text-xs font-medium text-muted-foreground uppercase">Total</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border">
          <% @purchase_order.items.includes(:product).each_with_index do |item, index| %>
            <tr>
              <td class="px-5 py-3 text-sm text-muted-foreground"><%= index + 1 %></td>
              <td class="px-5 py-3">
                <p class="text-sm font-medium text-foreground"><%= item.product.name %></p>
                <% if item.product.sku.present? %>
                  <p class="text-xs text-muted-foreground font-mono">SKU: <%= item.product.sku %></p>
                <% end %>
              </td>
              <td class="px-5 py-3 text-sm text-foreground text-right tabular-nums"><%= item.quantity %> <%= item.unit_label %></td>
              <td class="px-5 py-3 text-sm text-foreground text-right tabular-nums">S/ <%= number_with_precision(item.unit_price, precision: 2, delimiter: ",") %></td>
              <td class="px-5 py-3 text-sm font-medium text-foreground text-right tabular-nums">S/ <%= number_with_precision(item.total, precision: 2, delimiter: ",") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="px-5 py-4 border-t border-border">
      <div class="flex justify-end">
        <dl class="space-y-1.5 text-sm w-56">
          <div class="flex justify-between">
            <dt class="text-muted-foreground">Subtotal</dt>
            <dd class="font-medium text-foreground tabular-nums">S/ <%= number_with_precision(@purchase_order.subtotal, precision: 2, delimiter: ",") %></dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-muted-foreground">IGV (<%= (PeruTax::IGV_RATE * 100).to_i %>%)</dt>
            <dd class="font-medium text-foreground tabular-nums">S/ <%= number_with_precision(@purchase_order.tax, precision: 2, delimiter: ",") %></dd>
          </div>
          <div class="flex justify-between border-t border-border pt-1.5">
            <dt class="font-semibold text-foreground">Total</dt>
            <dd class="font-bold text-foreground text-base tabular-nums">S/ <%= number_with_precision(@purchase_order.total, precision: 2, delimiter: ",") %></dd>
          </div>
        </dl>
      </div>
    </div>
  </div>

  <% if @purchase_order.notes.present? %>
    <div class="card">
      <h3 class="text-xs font-medium text-muted-foreground uppercase tracking-wide mb-2">Notas</h3>
      <p class="text-sm text-foreground whitespace-pre-wrap"><%= @purchase_order.notes %></p>
    </div>
  <% end %>
</div>
