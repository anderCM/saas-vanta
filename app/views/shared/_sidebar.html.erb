<aside
  data-controller="sidebar"
  data-sidebar-collapsed-class="sidebar-collapsed"
  class="sidebar group"
  id="sidebar"
>
  <div class="sidebar-top">
    <div class="sidebar-logo">
      <div class="sidebar-logo-group">
        <div class="sidebar-logo-icon">
          <img src="/logo-vanta-fox.png" alt="VANTA" class="sidebar-logo-light w-full h-full object-contain">
          <img src="/logo-vanta-fox-dark.png" alt="VANTA" class="sidebar-logo-dark w-full h-full object-contain">
        </div>
        <span class="sidebar-logo-text" data-sidebar-target="collapsible">VANTA</span>
      </div>
      <button
        type="button"
        data-action="click->sidebar#toggle"
        class="sidebar-collapse-btn"
        title="Colapsar/Expandir menu"
      >
        <span data-sidebar-target="collapseIcon">
          <%= sidebar_icon("chevrons-left", class: "w-4 h-4") %>
        </span>
        <span data-sidebar-target="expandIcon" class="hidden">
          <%= sidebar_icon("chevrons-right", class: "w-4 h-4") %>
        </span>
      </button>
    </div>

    <nav class="sidebar-nav" aria-label="Menu principal">
      <%= sidebar_link_to "Dashboard", root_path, icon: "layout-dashboard" %>

      <% if current_enterprise.present? %>
        <%# === Comercial === %>
        <% if current_enterprise.module_enabled?(:ventas) %>
          <div class="sidebar-nav-section mt-4">
            <span class="sidebar-nav-section-label" data-sidebar-target="collapsible">Comercial</span>
          </div>
          <% if current_enterprise.module_enabled?("ventas.cotizaciones") %>
            <%= sidebar_link_to "Cotizaciones", customer_quotes_path, icon: "file-text" %>
          <% end %>
          <%
            has_facturas = current_enterprise.module_enabled?("facturacion.facturas")
            has_boletas = current_enterprise.module_enabled?("facturacion.boletas")
            has_subitems = has_facturas || has_boletas
          %>
          <% if has_subitems %>
            <%= sidebar_nav_group("Ventas", icon: "shopping-cart", key: "ventas") do %>
              <%= sidebar_link_to "Todas", sales_path, icon: "clipboard-list", sub: true %>
              <% if has_facturas %>
                <%= sidebar_link_to "Facturas", sales_path(doc_type: "factura"), icon: "receipt", sub: true %>
              <% end %>
              <% if has_boletas %>
                <%= sidebar_link_to "Boletas", sales_path(doc_type: "boleta"), icon: "receipt", sub: true %>
              <% end %>
            <% end %>
          <% else %>
            <%= sidebar_link_to "Ventas", sales_path, icon: "shopping-cart" %>
          <% end %>
        <% end %>

        <%# === Compras === %>
        <% if current_enterprise.module_enabled?(:compras) %>
          <div class="sidebar-nav-section mt-4">
            <span class="sidebar-nav-section-label" data-sidebar-target="collapsible">Compras</span>
          </div>
          <%= sidebar_link_to "Ordenes de compra", purchase_orders_path, icon: "package" %>
          <%= sidebar_link_to "Proveedores", providers_path, icon: "truck" %>
        <% end %>

        <%# === Despacho === %>
        <% if current_enterprise.module_enabled?(:despacho) %>
          <div class="sidebar-nav-section mt-4">
            <span class="sidebar-nav-section-label" data-sidebar-target="collapsible">Despacho</span>
          </div>
          <%= sidebar_link_to "Guias de remision", dispatch_guides_path, icon: "map" %>
          <% if current_enterprise.module_enabled?("despacho.vehiculos") %>
            <%= sidebar_link_to "Vehiculos", vehicles_path, icon: "car" %>
          <% end %>
          <% if current_enterprise.module_enabled?("despacho.transportistas") %>
            <%= sidebar_link_to "Transportistas", carriers_path, icon: "contact" %>
          <% end %>
        <% end %>

        <%# === Catálogo === %>
        <div class="sidebar-nav-section mt-4">
          <span class="sidebar-nav-section-label" data-sidebar-target="collapsible">Catalogo</span>
        </div>
        <%= sidebar_link_to "Productos", products_path, icon: "package" %>
        <%= sidebar_link_to "Clientes", customers_path, icon: "users" %>
        <%= sidebar_link_to "Importaciones", bulk_imports_path, icon: "upload" %>
      <% end %>
    </nav>
  </div>

  <div class="sidebar-bottom">
    <div class="sidebar-nav-section mb-1">
      <span class="sidebar-nav-section-label" data-sidebar-target="collapsible">Configuracion</span>
    </div>

    <button type="button" class="sidebar-theme-toggle" id="theme-toggle" title="Cambiar tema">
      <span class="theme-icon-dark">
        <%= sidebar_icon("moon", class: "w-4 h-4 flex-shrink-0") %>
      </span>
      <span class="theme-icon-light hidden">
        <%= sidebar_icon("sun", class: "w-4 h-4 flex-shrink-0") %>
      </span>
      <span class="sidebar-theme-toggle-text" data-sidebar-target="collapsible">
        <span class="theme-text-dark">Tema Oscuro</span>
        <span class="theme-text-light hidden">Tema Claro</span>
      </span>
    </button>

    <% if current_enterprise.present? && policy(current_enterprise).edit? %>
      <%= sidebar_link_to "Mi Empresa", edit_enterprise_path(current_enterprise), icon: "building-2" %>
    <% end %>

    <% if current_enterprise.present? && current_enterprise.module_enabled?(:facturacion) && policy(current_enterprise).sunat? %>
      <%= sidebar_link_to "Config. SUNAT", sunat_path, icon: "settings" %>
    <% end %>

    <% if current_enterprise.present? && policy(User).index? %>
      <%= sidebar_link_to "Usuarios", users_path, icon: "users" %>
    <% end %>

    <% if Current.user&.super_admin? %>
      <%= sidebar_link_to "Empresas", new_admin_enterprise_path, icon: "building-2" %>
    <% end %>

    <div class="sidebar-user">
      <div class="sidebar-user-avatar">
        <span class="text-xs font-semibold text-white">
          <%= Current.user&.first_name&.first&.upcase %><%= Current.user&.first_last_name&.first&.upcase %>
        </span>
      </div>
      <div class="sidebar-user-info" data-sidebar-target="collapsible">
        <span class="sidebar-user-name"><%= Current.user&.first_name %> <%= Current.user&.first_last_name&.first&.upcase %></span>
        <span class="sidebar-user-role">
          <%= Current.user&.super_admin? ? "Super Admin" : "Usuario" %>
        </span>
      </div>
      <%= link_to session_path, data: { turbo_method: :delete }, class: "sidebar-logout-btn", title: "Cerrar sesion" do %>
        <%= sidebar_icon("log-out", class: "w-4 h-4") %>
      <% end %>
    </div>
  </div>
</aside>
