<% content_for :page_title, "Dashboard" %>

<% if current_enterprise.present? %>
  <div class="max-w-7xl mx-auto space-y-6">

    <%# Quick Actions — first thing, most used %>
    <% actions = [] %>
    <% actions << { path: new_sale_path, icon: "shopping-cart", label: "Nueva Venta", hint: "Crear venta a cliente" } if ventas_enabled? && policy(Sale).create? %>
    <% actions << { path: new_customer_quote_path, icon: "file-text", label: "Nueva Cotizacion", hint: "Preparar propuesta" } if cotizaciones_enabled? && policy(CustomerQuote).create? %>
    <% actions << { path: new_purchase_order_path, icon: "package", label: "Nueva Orden de Compra", hint: "Pedir a proveedor" } if compras_enabled? && policy(PurchaseOrder).create? %>
    <% if actions.any? %>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 max-w-3xl">
        <% actions.each do |action| %>
          <%= link_to action[:path], class: "quick-action" do %>
            <div class="quick-action-icon">
              <%= sidebar_icon(action[:icon], class: "w-4 h-4") %>
            </div>
            <div>
              <div class="quick-action-label"><%= action[:label] %></div>
              <div class="quick-action-hint"><%= action[:hint] %></div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% end %>

    <%# Metrics — adaptive to enabled modules %>
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
      <% if ventas_enabled? %>
        <div class="metric-card">
          <span class="metric-card-label">Ventas del mes</span>
          <span class="metric-card-value">S/ <%= number_with_precision(@sales_total_month, precision: 2, delimiter: ",") %></span>
          <span class="text-xs text-muted-foreground"><%= @sales_count %> confirmadas</span>
        </div>

        <div class="metric-card">
          <span class="metric-card-label">Ventas pendientes</span>
          <span class="metric-card-value"><%= @sales_pending %></span>
          <span class="text-xs text-muted-foreground">Por confirmar</span>
        </div>
      <% end %>

      <% if cotizaciones_enabled? %>
        <div class="metric-card">
          <span class="metric-card-label">Cotizaciones</span>
          <span class="metric-card-value"><%= @quotes_pending %></span>
          <span class="text-xs text-muted-foreground">Pendientes de respuesta</span>
        </div>
      <% end %>

      <% if compras_enabled? %>
        <div class="metric-card">
          <span class="metric-card-label">Ordenes de compra</span>
          <span class="metric-card-value"><%= @po_pending %></span>
          <span class="text-xs text-muted-foreground">Pendientes</span>
        </div>
      <% end %>

      <% if credito_enabled? %>
        <div class="metric-card">
          <span class="metric-card-label">Credito por cobrar</span>
          <span class="metric-card-value">S/ <%= number_with_precision(@total_pending_credit, precision: 2, delimiter: ",") %></span>
          <span class="text-xs text-muted-foreground">Cuotas pendientes</span>
        </div>
      <% end %>
    </div>

    <%# Charts — only if ventas is enabled %>
    <% if ventas_enabled? %>
      <div class="grid grid-cols-1 <%= cotizaciones_enabled? ? 'lg:grid-cols-3' : '' %> gap-6">
        <%# Monthly sales chart — takes 2/3 when quotes enabled, full width when not %>
        <div class="card <%= cotizaciones_enabled? ? 'lg:col-span-2' : '' %>">
          <h3 class="text-sm font-semibold text-foreground mb-4">Ventas por mes</h3>
          <%= column_chart @monthly_sales,
                prefix: "S/ ",
                thousands: ",",
                colors: ["#059669"],
                library: {
                  plugins: { legend: { display: false } },
                  scales: {
                    y: { grid: { color: "rgba(0,0,0,0.04)" }, ticks: { font: { size: 11 } } },
                    x: { grid: { display: false }, ticks: { font: { size: 11 } } }
                  }
                },
                height: "260px" %>
        </div>

        <% if cotizaciones_enabled? %>
          <div class="card">
            <h3 class="text-sm font-semibold text-foreground mb-4">Cotizaciones del mes</h3>
            <% if @quotes_by_status.any? %>
              <%= pie_chart @quotes_by_status,
                    donut: true,
                    colors: ["#6B7280", "#059669", "#DC2626", "#2563EB"],
                    library: {
                      plugins: { legend: { position: "bottom", labels: { font: { size: 11 }, padding: 12, usePointStyle: true } } }
                    },
                    height: "232px" %>
            <% else %>
              <div class="flex items-center justify-center h-[232px]">
                <p class="text-sm text-muted-foreground">Sin cotizaciones este mes</p>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>

      <%# Top customers — horizontal bars %>
      <% if @top_customers.any? %>
        <div class="card">
          <h3 class="text-sm font-semibold text-foreground mb-4">Top clientes del mes</h3>
          <%= bar_chart @top_customers,
                prefix: "S/ ",
                thousands: ",",
                colors: ["#059669"],
                library: {
                  indexAxis: "y",
                  plugins: { legend: { display: false } },
                  scales: {
                    x: { grid: { color: "rgba(0,0,0,0.04)" }, ticks: { font: { size: 11 } } },
                    y: { grid: { display: false }, ticks: { font: { size: 11 } } }
                  }
                },
                height: "200px" %>
        </div>
      <% end %>
    <% end %>

    <%# Recent Activity — adaptive columns %>
    <% show_sales_list = ventas_enabled? %>
    <% show_quotes_list = cotizaciones_enabled? %>
    <% if show_sales_list || show_quotes_list %>
      <div class="grid grid-cols-1 <%= (show_sales_list && show_quotes_list) ? 'lg:grid-cols-2' : '' %> gap-6">
        <% if show_sales_list %>
          <div class="card p-0">
            <div class="flex items-center justify-between px-5 py-4 border-b border-border">
              <h3 class="text-sm font-semibold text-foreground">Ventas recientes</h3>
              <%= link_to "Ver todas", sales_path, class: "text-xs text-primary hover:text-primary/80 font-medium" %>
            </div>
            <% if @recent_sales.any? %>
              <div class="divide-y divide-border">
                <% @recent_sales.each do |sale| %>
                  <%= link_to sale, class: "flex items-center justify-between px-5 py-3 hover:bg-muted/50 transition-colors" do %>
                    <div class="min-w-0">
                      <div class="text-sm font-medium text-foreground truncate"><%= sale.customer.name %></div>
                      <div class="text-xs text-muted-foreground"><%= sale.code %> &middot; <%= l(sale.issue_date, format: :short) %></div>
                    </div>
                    <div class="flex items-center gap-3 flex-shrink-0 ml-3">
                      <span class="text-sm font-medium text-foreground tabular-nums">S/ <%= number_with_precision(sale.total, precision: 2, delimiter: ",") %></span>
                      <span class="<%= sale.status_badge_class %>"><%= sale.status_label %></span>
                    </div>
                  <% end %>
                <% end %>
              </div>
            <% else %>
              <div class="px-5 py-8 text-center">
                <p class="text-sm text-muted-foreground">No hay ventas recientes</p>
              </div>
            <% end %>
          </div>
        <% end %>

        <% if show_quotes_list %>
          <div class="card p-0">
            <div class="flex items-center justify-between px-5 py-4 border-b border-border">
              <h3 class="text-sm font-semibold text-foreground">Cotizaciones recientes</h3>
              <%= link_to "Ver todas", customer_quotes_path, class: "text-xs text-primary hover:text-primary/80 font-medium" %>
            </div>
            <% if @recent_quotes.any? %>
              <div class="divide-y divide-border">
                <% @recent_quotes.each do |quote| %>
                  <%= link_to quote, class: "flex items-center justify-between px-5 py-3 hover:bg-muted/50 transition-colors" do %>
                    <div class="min-w-0">
                      <div class="text-sm font-medium text-foreground truncate"><%= quote.customer.name %></div>
                      <div class="text-xs text-muted-foreground"><%= quote.code %> &middot; <%= l(quote.issue_date, format: :short) %></div>
                    </div>
                    <div class="flex items-center gap-3 flex-shrink-0 ml-3">
                      <span class="text-sm font-medium text-foreground tabular-nums">S/ <%= number_with_precision(quote.total, precision: 2, delimiter: ",") %></span>
                      <span class="<%= quote.status_badge_class %>"><%= quote.status_label %></span>
                    </div>
                  <% end %>
                <% end %>
              </div>
            <% else %>
              <div class="px-5 py-8 text-center">
                <p class="text-sm text-muted-foreground">No hay cotizaciones recientes</p>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# Upcoming installments — only if credit module enabled %>
    <% if credito_enabled? && @upcoming_installments.present? %>
      <div class="card p-0">
        <div class="flex items-center justify-between px-5 py-4 border-b border-border">
          <h3 class="text-sm font-semibold text-foreground">Cuotas proximas a vencer</h3>
        </div>
        <div class="divide-y divide-border">
          <% @upcoming_installments.each do |installment| %>
            <%= link_to installment.sale, class: "flex items-center justify-between px-5 py-3 hover:bg-muted/50 transition-colors" do %>
              <div class="min-w-0">
                <div class="text-sm font-medium text-foreground truncate"><%= installment.sale.customer.name %></div>
                <div class="text-xs text-muted-foreground">
                  <%= installment.sale.code %> &middot; Cuota #<%= installment.installment_number %>
                </div>
              </div>
              <div class="flex items-center gap-3 flex-shrink-0 ml-3">
                <span class="text-sm font-medium text-foreground tabular-nums">S/ <%= number_with_precision(installment.amount, precision: 2, delimiter: ",") %></span>
                <span class="<%= installment.due_date < Date.current ? 'badge-destructive' : installment.due_date <= 7.days.from_now ? 'badge-warning' : 'badge-secondary' %>">
                  <%= l(installment.due_date, format: :short) %>
                </span>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="flex items-center justify-center min-h-[60vh]">
    <div class="text-center">
      <h2 class="text-xl font-semibold text-foreground mb-2">Bienvenido a VANTA</h2>
      <p class="text-muted-foreground">Selecciona una empresa para comenzar.</p>
    </div>
  </div>
<% end %>
